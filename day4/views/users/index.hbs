<h1 class="mb-4">{{title}}</h1>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>Action</th>
        </tr>
        {{#each users}}
        <tr>
            <td>{{this.id}}</td>
            <td>{{this.name}}</td>
            <td>{{this.email}}</td>
            <td>
                <a href="/users/{{this.id}}" class="btn btn-info">View</a>
            </td>
        </tr>
        {{/each}}
    </thead>
    <tbody>

    </tbody>
</table>