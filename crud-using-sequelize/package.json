{
  "name": "crud-using-sequelize",
  "version": "1.0.0",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "migrate": "sequelize-cli db:migrate --config src/config/database.cjs --migrations-path src/migrations",
    "migrate:undo": "sequelize-cli db:migrate:undo --config src/config/database.cjs --migrations-path src/migrations",
    "migrate:fresh": "sequelize-cli db:migrate:undo:all --config src/config/database.cjs --migrations-path src/migrations && sequelize-cli db:migrate --config src/config/database.cjs --migrations-path src/migrations",
    "migrate:status": "sequelize-cli db:migrate:status --config src/config/database.cjs --migrations-path src/migrations",
    "seed": "sequelize-cli db:seed:all --config src/config/database.cjs --seeders-path src/seeders",
    "seed:undo": "sequelize-cli db:seed:undo:all --config src/config/database.cjs --seeders-path src/seeders"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "joi": "^18.1.2",
    "mysql2": "^3.22.1",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.5"
  }
}